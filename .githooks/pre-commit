#!/usr/bin/env sh
# Pre-commit hook — runs gitleaks against staged changes only.
#
# Activate once per developer machine:
#   git config core.hooksPath .githooks
#
# Requires gitleaks on PATH:
#   - macOS:    brew install gitleaks
#   - Windows:  scoop install gitleaks    (or download from
#               https://github.com/gitleaks/gitleaks/releases)
#   - Linux:    your package manager, or the GitHub release tarball
#
# When the hook trips, gitleaks prints the offending file + rule. Fix
# the leak (or extend .gitleaks.toml if it's a genuine false positive)
# and re-stage.

if ! command -v gitleaks >/dev/null 2>&1; then
  printf '\033[33m[pre-commit] gitleaks not installed — secret scan skipped.\033[0m\n' >&2
  printf '\033[33m[pre-commit] Install via your package manager or https://github.com/gitleaks/gitleaks/releases\033[0m\n' >&2
  exit 0
fi

gitleaks protect --staged --redact --config .gitleaks.toml
status=$?

if [ $status -ne 0 ]; then
  printf '\n\033[31m[pre-commit] gitleaks found likely secrets in staged changes — commit blocked.\033[0m\n' >&2
  printf '\033[31m[pre-commit] Fix the leak or add an allowlist entry in .gitleaks.toml.\033[0m\n' >&2
  exit $status
fi

exit 0
