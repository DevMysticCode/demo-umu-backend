# compiled output
/dist
/node_modules
/build

# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS
.DS_Store

# Tests
/coverage
/.nyc_output

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Secrets — credentials, certs, keys must never be committed.
/secrets/
*.pfx
*.p12
*.pem
*.key
*.cer

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# temp directory
.temp
.tmp

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

/generated/prisma

# User uploads — production stores in S3, local dev writes here.
uploads/

# Claude Code per-developer permissions (never commit — contains shell
# allow-list that may capture creds in command lines). Shared config
# goes in .claude/settings.json.
.claude/settings.local.json
.claude/*.local.json

# Confidential audit / due-diligence reports (kept locally, never committed)
*Gap-Analysis*.pdf
*-Gap-Analysis*.pdf
prisma/*Gap-Analysis*
*ReReview*.pdf
*Re-Review*.pdf
*DF4_Labs*.pdf
prisma/*DF4*

# Enrichment debug dumps — these were one-time captures of live API
# responses that included real API keys in URL params. Regenerate
# locally if you need them; do NOT commit.
enrich.json
enrich*.json

# Secret JSON files consumed by infra/scripts/populate-secrets.ps1.
# The .example.json is the only one that ships.
prod-secrets.json
*-secrets.json
!*.example.json
# Local dev-only smoke tests — hit real HMLR endpoints, not for CI.
scripts/hmlr-llc-smoketest.mjs
