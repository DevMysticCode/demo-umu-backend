generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  password               String
  createdAt              DateTime               @default(now())
  dob                    DateTime?
  firstName              String?
  gender                 String?
  isVerified             Boolean                @default(false)
  lastName               String?
  phone                  String?
  postcode               String?
  avatarUrl              String?
  contactVisible         Boolean                @default(true)
  pushNotifications      Boolean                @default(true)
  emailNewsletter        Boolean                @default(true)
  smsNotifications       Boolean                @default(false)
  passports              Passport[]
  passportCollaborations PassportCollaborator[]
  preference             UserPreference?
  collections            PassportCollection[]
  buyerPassportAccesses  BuyerPassportAccess[]
  addresses              UserAddress[]
  companies              UserCompany[]
  solicitors             UserSolicitor[]
  collaboratorsAdded     UserCollaborator[]     @relation("CollaboratorOwner")
  collaboratorOf         UserCollaborator[]     @relation("CollaboratorUser")
  userDocuments          UserDocument[]
  wishlistedProperties   UserWishlist[]
  savedProperties        UserSavedProperty[]
  reminders              UserReminder[]
  videoProgress          VideoProgress[]
  buyerNotes             BuyerNote[]
}

model UserAddress {
  id        String   @id @default(uuid())
  userId    String
  label     String
  line1     String
  line2     String?
  city      String?
  county    String?
  postcode  String
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserCompany {
  id            String   @id @default(uuid())
  userId        String
  name          String
  address       String?
  companyNumber String?
  director      String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSolicitor {
  id          String   @id @default(uuid())
  userId      String
  name        String
  address     String?
  contactName String?
  email       String?
  phone       String?
  reference   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Property {
  id                     String                  @id @default(uuid())
  udprn                  String?                 @unique
  uprn                   String?                 @unique
  addressLine1           String
  addressLine2           String?
  city                   String?
  county                 String?
  postcode               String
  latitude               Float?
  longitude              Float?
  propertyType           String?
  bedrooms               Int?
  bathrooms              Int?
  sqft                   Int?
  floorAreaSqm           Float?
  epcRating              String?
  epcScore               Int?
  heatingType            String?
  co2Emissions           Float?
  tenure                 String?
  yearBuilt              Int?
  estimatedPrice         Float?
  lastSoldPrice          Float?
  lastSoldDate           DateTime?
  councilTaxBand         String?
  floodRisk              String?
  imageUrl               String?
  images                 Json?
  titleNumber            String?
  epcEnrichedAt          DateTime?
  createdAt              DateTime                @default(now())

  // ── HomeScore V2 EPC cost fields ─────────────────────────────────────────
  heatingCostCurrent     Float?   // EPC heating-cost-current (£/yr)
  hotWaterCostCurrent    Float?   // EPC hot-water-cost-current (£/yr)
  lightingCostCurrent    Float?   // EPC lighting-cost-current (£/yr)

  // ── HomeScore V2 insulation fields ───────────────────────────────────────
  wallsEnergyEff         String?  // "Very Good" | "Good" | "Average" | "Poor" | "Very Poor"
  roofEnergyEff          String?
  floorEnergyEff         String?
  floorDescription       String?  // used to detect "assumed" no insulation
  windowsEnergyEff       String?
  glazedArea             String?  // "Less than typical" | "Normal" | "More than typical" | "Much more than typical"
  multiGlazeProportion   Float?   // 0–100 percentage

  // ── HomeScore V2 heating fields ──────────────────────────────────────────
  mainheatEnergyEff      String?  // main heating system efficiency rating
  mainheatcEnergyEff     String?  // heating controls efficiency rating
  hotWaterEnergyEff      String?
  hotwaterDescription    String?  // used to detect "no cylinder thermostat"
  secondheatDescription  String?  // secondary heating type (for penalty)
  mainheatcontDescription String? // controls description

  // ── HomeScore V2 ventilation ─────────────────────────────────────────────
  mechanicalVentilation  String?  // "natural" | "balanced with heat recovery" | etc.

  // ── HomeScore V2 lighting ────────────────────────────────────────────────
  lightingEnergyEff      String?
  lowEnergyLighting      Float?   // percentage 0–100

  // ── HomeScore V2 renewables ──────────────────────────────────────────────
  photoSupply            Float?   // solar PV supply (kW) — >0 means PV present
  solarWaterHeatingFlag  String?  // "Y" | "N"
  windTurbineCount       Int?

  // ── HomeScore V2 EPC metadata ────────────────────────────────────────────
  lodgementDate          String?  // EPC lodgement date (YYYY-MM-DD)
  constructionAgeBand    String?  // e.g. "1930-1949"
  builtForm              String?  // "Detached" | "Semi-Detached" | "Mid-Terrace" | etc.

  passport               Passport?
  ownershipVerifications OwnershipVerification[]
  wishlistedBy           UserWishlist[]
  savedBy                UserSavedProperty[]

  @@index([postcode])
  @@index([uprn])
}

model OwnershipVerification {
  id          String                      @id @default(uuid())
  propertyId  String
  userId      String
  status      OwnershipVerificationStatus @default(SUBMITTED)
  submittedAt DateTime                    @default(now())
  verifiedAt  DateTime?
  passportId  String?
  property    Property                    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@index([userId])
}

model UserPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  purpose           Json?
  buyingTimeline    String?
  budgetMin         Float?
  budgetMax         Float?
  propertyTypes     Json?
  propertyStyles    Json?
  importantFeatures Json?
  sellingTimeline   String?
  propertyValue     Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SectionTemplate {
  id                String             @id @default(uuid())
  key               String             @unique
  title             String
  subtitle          String?
  description       String?
  icon              String?
  helpContent       Json?
  helpVideoUrl      String?
  order             Int
  createdAt         DateTime           @default(now())
  questionTemplates QuestionTemplate[]
}

model Passport {
  id            String                 @id @default(uuid())
  addressLine1  String                 @unique
  postcode      String
  ownerId       String
  propertyId    String?                @unique
  status        PassportStatus         @default(IN_PROGRESS)
  createdAt     DateTime               @default(now())
  owner         User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  property      Property?              @relation(fields: [propertyId], references: [id])
  sections      PassportSection[]
  collaborators   PassportCollaborator[]
  collectionItems PassportCollectionItem[]
  buyerAccesses   BuyerPassportAccess[]
  sharedLinks     SharedPassportLink[]
  buyerNotes      BuyerNote[]

  @@index([ownerId])
}

model PassportCollection {
  id        String                  @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime                @default(now())
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PassportCollectionItem[]

  @@index([userId])
}

model PassportCollectionItem {
  id           String             @id @default(uuid())
  collectionId String
  passportId   String
  collection   PassportCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  passport     Passport           @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@unique([collectionId, passportId])
  @@index([collectionId])
}

model PassportCollaborator {
  id         String   @id @default(uuid())
  passportId String
  userId     String
  createdAt  DateTime @default(now())
  passport   Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([passportId, userId])
  @@index([passportId])
  @@index([userId])
}

model UserCollaborator {
  id             String    @id @default(uuid())
  userId         String
  collaboratorId String
  role           String?
  permission     String?   @default("all")
  propertyIds    Json?
  accessDuration String?   @default("permanent")
  expiresAt      DateTime?
  clientAccess   String?   @default("shared")
  allowComms     Boolean   @default(true)
  createdAt      DateTime  @default(now())
  user           User      @relation("CollaboratorOwner", fields: [userId], references: [id], onDelete: Cascade)
  collaborator   User      @relation("CollaboratorUser", fields: [collaboratorId], references: [id], onDelete: Cascade)

  @@unique([userId, collaboratorId])
  @@index([userId])
  @@index([collaboratorId])
}

model BuyerPassportAccess {
  id         String   @id @default(uuid())
  passportId String
  userId     String
  unlockedAt DateTime @default(now())
  passport   Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([passportId, userId])
  @@index([passportId])
  @@index([userId])
}

model PassportSection {
  id          String                @id @default(uuid())
  passportId  String
  key         String
  title       String
  subtitle    String?
  description String?
  imageKey    String?
  order       Int
  status      SectionStatus         @default(LOCKED)
  createdAt   DateTime              @default(now())
  passport    Passport              @relation(fields: [passportId], references: [id], onDelete: Cascade)
  tasks       PassportSectionTask[]

  @@unique([passportId, key])
  @@index([passportId])
}

model PassportSectionTask {
  id                String             @id @default(uuid())
  passportSectionId String
  key               String
  title             String
  description       String?
  icon              String?
  order             Int
  status            TaskStatus         @default(PENDING)
  createdAt         DateTime           @default(now())
  passportQuestions PassportQuestion[]
  passportSection   PassportSection    @relation(fields: [passportSectionId], references: [id], onDelete: Cascade)

  @@unique([passportSectionId, key])
  @@index([passportSectionId])
}

model QuestionTemplate {
  id                  String             @id @default(uuid())
  sectionKey          String
  taskKey             String
  title               String
  description         String?
  instructionText     String?
  helpText            String?
  helpContent         Json?
  helpVideoUrl        String?
  type                QuestionType
  options             Json?
  placeholder         String?
  displayMode         String?
  uploadInstruction   String?
  prewrittenTemplates Json?
  dateFields          Json?
  parts               Json?
  fields              Json?
  autoSaveOn          Json?
  repeatable          Boolean?
  buttonText          String?
  scaleType           String?
  scaleMin            Int?
  scaleMax            Int?
  scaleStep           Int?
  scaleFormat         String?
  scaleMaxLabel       String?
  externalLink        Json?
  otherPlaceholder    String?
  points              Int
  order               Int
  createdAt           DateTime           @default(now())
  passportQuestions   PassportQuestion[]
  sectionTemplate     SectionTemplate    @relation(fields: [sectionKey], references: [key])

  @@index([sectionKey, taskKey])
}

model PassportQuestion {
  id                    String              @id @default(uuid())
  passportSectionTaskId String
  questionTemplateId    String
  status                QuestionStatus      @default(PENDING)
  createdAt             DateTime            @default(now())
  passportSectionTask   PassportSectionTask @relation(fields: [passportSectionTaskId], references: [id], onDelete: Cascade)
  questionTemplate      QuestionTemplate    @relation(fields: [questionTemplateId], references: [id])
  answer                QuestionAnswer?

  @@index([passportSectionTaskId])
  @@index([questionTemplateId])
}

model QuestionAnswer {
  id                 String           @id @default(uuid())
  passportQuestionId String           @unique
  answerText         String?
  answerJson         Json?
  fileUrl            String?
  createdAt          DateTime         @default(now())
  passportQuestion   PassportQuestion @relation(fields: [passportQuestionId], references: [id], onDelete: Cascade)
}

model UserWishlist {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
}

model UserSavedProperty {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
}

model UserReminder {
  id        String   @id @default(uuid())
  userId    String
  title     String
  date      DateTime // stored as UTC date (no time component)
  time      String?  // "14:00" HH:mm format
  repeats   String   @default("never") // "never" | "annually"
  notes     String?
  type      String   @default("manual") // "manual" | "tradesperson" | "business"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model UserDocument {
  id        String    @id @default(uuid())
  userId    String
  name      String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  tags      Json?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum PassportStatus {
  IN_PROGRESS
  COMPLETED
  PUBLISHED
}

enum OwnershipVerificationStatus {
  SUBMITTED
  IN_PROGRESS
  VERIFIED
  FAILED
  ADDITIONAL_INFO_NEEDED
}

enum SectionStatus {
  LOCKED
  ACTIVE
  COMPLETED
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum QuestionStatus {
  PENDING
  COMPLETED
}

enum QuestionType {
  TEXT
  RADIO
  CHECKBOX
  UPLOAD
  MULTIPART
  NOTE
  DATE
  ADDRESS
  MULTITEXTINPUT
  MULTIFIELDFORM
  SCALE
  CHIPS
  BOUNDARY
}

model SupportRequest {
  id           String   @id @default(uuid())
  ticketNumber String   @unique
  name         String
  email        String
  subject      String
  message      String
  status       String   @default("open")
  createdAt    DateTime @default(now())
}

model Video {
  id          String          @id @default(uuid())
  title       String
  description String?
  url         String
  thumbnail   String?
  durationSec Int             @default(0)
  points      Int             @default(15)
  category    String?
  tags        String[]
  order       Int             @default(0)
  featured    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  progress    VideoProgress[]
}

model VideoProgress {
  id           String   @id @default(uuid())
  userId       String
  videoId      String
  positionSecs Int      @default(0)
  completed    Boolean  @default(false)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId])
}

model HomeScoreResult {
  id          String   @id @default(uuid())
  propertyId  String
  userId      String
  total       Int
  rating      String
  answers     Json

  // ── V2 fields (all nullable — V1 records remain valid) ───────────────────
  tier             String?  // "estimated" | "verified" | "certified"
  baseBill         Float?   // estimated annual energy bill from EPC (£)
  adjustedBill     Float?   // recency-adjusted bill (£)
  actualBill       Float?   // user-entered real bill for Tier 2 (£)
  costPerSqm       Float?
  neighbourMedian  Float?   // median annual bill for similar neighbourhood properties (£)
  billDifference   Float?   // positive = paying more than median, negative = paying less

  // V2 component scores (0–5 scale before weighting)
  costEfficiency   Float?
  insulation       Float?
  heating          Float?
  controls         Float?
  ventilation      Float?
  lighting         Float?
  renewableBonus   Float?

  // V1 component scores (kept for backward compat)
  heatingV1    Int?
  structure    Int?
  efficiency   Int?
  electrics    Int?
  plumbing     Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@index([userId])
}

model SharedPassportLink {
  id         String   @id @default(uuid())
  passportId String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  passport   Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([passportId])
}

model BuyerNote {
  id         String   @id @default(uuid())
  passportId String
  userId     String
  sectionKey String?
  text       String
  createdAt  DateTime @default(now())
  passport   Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([passportId, userId])
}

// HM Land Registry Price Paid Data — imported via scripts/import-price-paid.ts
model PricePaidTransaction {
  id              String   @id @default(uuid())
  transactionId   String   @unique // Land Registry transaction ID (e.g. {GUID})
  price           Int
  transactionDate DateTime
  postcode        String
  propertyType    String?  // D=Detached, S=Semi-detached, T=Terraced, F=Flat, O=Other
  isNewBuild      Boolean  @default(false)
  tenure          String?  // F=Freehold, L=Leasehold, U=Unknown
  paon            String?  // Primary Addressable Object Name (house number/name)
  saon            String?  // Secondary Addressable Object Name (flat/unit)
  street          String?
  locality        String?
  town            String?
  district        String?
  county          String?
  category        String?  // A=Standard, B=Additional (non-standard)

  @@index([postcode])
  @@index([postcode, paon])
  @@index([transactionDate])
}
