generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  password               String
  createdAt              DateTime               @default(now())
  dob                    DateTime?
  firstName              String?
  gender                 String?
  isVerified             Boolean                @default(false)
  lastName               String?
  phone                  String?
  postcode               String?
  avatarUrl              String?
  contactVisible         Boolean                @default(true)
  pushNotifications      Boolean                @default(true)
  emailNewsletter        Boolean                @default(true)
  smsNotifications       Boolean                @default(false)
  passports              Passport[]
  passportCollaborations PassportCollaborator[]
  preference             UserPreference?
  collections            PassportCollection[]
  buyerPassportAccesses  BuyerPassportAccess[]
  addresses              UserAddress[]
  companies              UserCompany[]
  solicitors             UserSolicitor[]
  collaboratorsAdded     UserCollaborator[]     @relation("CollaboratorOwner")
  collaboratorOf         UserCollaborator[]     @relation("CollaboratorUser")
}

model UserAddress {
  id        String   @id @default(uuid())
  userId    String
  label     String
  line1     String
  line2     String?
  city      String?
  county    String?
  postcode  String
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserCompany {
  id            String   @id @default(uuid())
  userId        String
  name          String
  address       String?
  companyNumber String?
  director      String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSolicitor {
  id          String   @id @default(uuid())
  userId      String
  name        String
  address     String?
  contactName String?
  email       String?
  phone       String?
  reference   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Property {
  id                     String                  @id @default(uuid())
  udprn                  String?                 @unique
  addressLine1           String
  addressLine2           String?
  city                   String?
  county                 String?
  postcode               String
  latitude               Float?
  longitude              Float?
  propertyType           String?
  bedrooms               Int?
  bathrooms              Int?
  sqft                   Int?
  epcRating              String?
  tenure                 String?
  yearBuilt              Int?
  estimatedPrice         Float?
  imageUrl               String?
  titleNumber            String?
  createdAt              DateTime                @default(now())
  passport               Passport?
  ownershipVerifications OwnershipVerification[]

  @@index([postcode])
}

model OwnershipVerification {
  id          String                      @id @default(uuid())
  propertyId  String
  userId      String
  status      OwnershipVerificationStatus @default(SUBMITTED)
  submittedAt DateTime                    @default(now())
  verifiedAt  DateTime?
  passportId  String?
  property    Property                    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, userId])
  @@index([propertyId])
  @@index([userId])
}

model UserPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  purpose           Json?
  buyingTimeline    String?
  budgetMin         Float?
  budgetMax         Float?
  propertyTypes     Json?
  propertyStyles    Json?
  importantFeatures Json?
  sellingTimeline   String?
  propertyValue     Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SectionTemplate {
  id                String             @id @default(uuid())
  key               String             @unique
  title             String
  subtitle          String?
  description       String?
  icon              String?
  order             Int
  createdAt         DateTime           @default(now())
  questionTemplates QuestionTemplate[]
}

model Passport {
  id            String                 @id @default(uuid())
  addressLine1  String                 @unique
  postcode      String
  ownerId       String
  propertyId    String?                @unique
  status        PassportStatus         @default(IN_PROGRESS)
  createdAt     DateTime               @default(now())
  owner         User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  property      Property?              @relation(fields: [propertyId], references: [id])
  sections      PassportSection[]
  collaborators   PassportCollaborator[]
  collectionItems PassportCollectionItem[]
  buyerAccesses   BuyerPassportAccess[]

  @@index([ownerId])
}

model PassportCollection {
  id        String                  @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime                @default(now())
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PassportCollectionItem[]

  @@index([userId])
}

model PassportCollectionItem {
  id           String             @id @default(uuid())
  collectionId String
  passportId   String
  collection   PassportCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  passport     Passport           @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@unique([collectionId, passportId])
  @@index([collectionId])
}

model PassportCollaborator {
  id         String   @id @default(uuid())
  passportId String
  userId     String
  createdAt  DateTime @default(now())
  passport   Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([passportId, userId])
  @@index([passportId])
  @@index([userId])
}

model UserCollaborator {
  id             String    @id @default(uuid())
  userId         String
  collaboratorId String
  role           String?
  permission     String?   @default("all")
  accessDuration String?   @default("permanent")
  expiresAt      DateTime?
  clientAccess   String?   @default("shared")
  allowComms     Boolean   @default(true)
  createdAt      DateTime  @default(now())
  user           User      @relation("CollaboratorOwner", fields: [userId], references: [id], onDelete: Cascade)
  collaborator   User      @relation("CollaboratorUser", fields: [collaboratorId], references: [id], onDelete: Cascade)

  @@unique([userId, collaboratorId])
  @@index([userId])
  @@index([collaboratorId])
}

model BuyerPassportAccess {
  id         String   @id @default(uuid())
  passportId String
  userId     String
  unlockedAt DateTime @default(now())
  passport   Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([passportId, userId])
  @@index([passportId])
  @@index([userId])
}

model PassportSection {
  id          String                @id @default(uuid())
  passportId  String
  key         String
  title       String
  subtitle    String?
  description String?
  imageKey    String?
  order       Int
  status      SectionStatus         @default(LOCKED)
  createdAt   DateTime              @default(now())
  passport    Passport              @relation(fields: [passportId], references: [id], onDelete: Cascade)
  tasks       PassportSectionTask[]

  @@unique([passportId, key])
  @@index([passportId])
}

model PassportSectionTask {
  id                String             @id @default(uuid())
  passportSectionId String
  key               String
  title             String
  description       String?
  icon              String?
  order             Int
  status            TaskStatus         @default(PENDING)
  createdAt         DateTime           @default(now())
  passportQuestions PassportQuestion[]
  passportSection   PassportSection    @relation(fields: [passportSectionId], references: [id], onDelete: Cascade)

  @@unique([passportSectionId, key])
  @@index([passportSectionId])
}

model QuestionTemplate {
  id                  String             @id @default(uuid())
  sectionKey          String
  taskKey             String
  title               String
  description         String?
  instructionText     String?
  helpText            String?
  type                QuestionType
  options             Json?
  placeholder         String?
  displayMode         String?
  uploadInstruction   String?
  prewrittenTemplates Json?
  dateFields          Json?
  parts               Json?
  fields              Json?
  autoSaveOn          Json?
  repeatable          Boolean?
  buttonText          String?
  scaleType           String?
  scaleMin            Int?
  scaleMax            Int?
  scaleStep           Int?
  scaleFormat         String?
  scaleMaxLabel       String?
  externalLink        Json?
  otherPlaceholder    String?
  points              Int
  order               Int
  createdAt           DateTime           @default(now())
  passportQuestions   PassportQuestion[]
  sectionTemplate     SectionTemplate    @relation(fields: [sectionKey], references: [key])

  @@index([sectionKey, taskKey])
}

model PassportQuestion {
  id                    String              @id @default(uuid())
  passportSectionTaskId String
  questionTemplateId    String
  status                QuestionStatus      @default(PENDING)
  createdAt             DateTime            @default(now())
  passportSectionTask   PassportSectionTask @relation(fields: [passportSectionTaskId], references: [id], onDelete: Cascade)
  questionTemplate      QuestionTemplate    @relation(fields: [questionTemplateId], references: [id])
  answer                QuestionAnswer?

  @@index([passportSectionTaskId])
  @@index([questionTemplateId])
}

model QuestionAnswer {
  id                 String           @id @default(uuid())
  passportQuestionId String           @unique
  answerText         String?
  answerJson         Json?
  fileUrl            String?
  createdAt          DateTime         @default(now())
  passportQuestion   PassportQuestion @relation(fields: [passportQuestionId], references: [id], onDelete: Cascade)
}

enum PassportStatus {
  IN_PROGRESS
  COMPLETED
}

enum OwnershipVerificationStatus {
  SUBMITTED
  IN_PROGRESS
  VERIFIED
  FAILED
  ADDITIONAL_INFO_NEEDED
}

enum SectionStatus {
  LOCKED
  ACTIVE
  COMPLETED
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum QuestionStatus {
  PENDING
  COMPLETED
}

enum QuestionType {
  TEXT
  RADIO
  CHECKBOX
  UPLOAD
  MULTIPART
  NOTE
  DATE
  ADDRESS
  MULTITEXTINPUT
  MULTIFIELDFORM
  SCALE
  CHIPS
  BOUNDARY
}
