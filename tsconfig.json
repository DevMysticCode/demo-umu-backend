{
  // infra/ is the AWS CDK project — separate package.json + node_modules,
  // its own tsconfig.json. Without this exclude, Nest/TS in the backend
  // root tries to compile CDK files and fails on Railway/CI where
  // infra/node_modules isn't installed (we only `npm install` the
  // backend's deps).
  "exclude": ["infra", "node_modules", "dist"],
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}
